# Tier 0 — Sphere primitive, closed-form ground truth.
# Volume = 4/3*pi*r^3, surface area = 4*pi*r^2. See VALIDATION_STRENGTHENING.md Appendix.
#
# `watertight: true` uses the BREP-level check (KNOWN_LIMITATIONS.md #8,
# fixed 2026-07-18): the old mesh-based check (STL export + trimesh) reported
# False here at every size/tessellation tolerance tried, because OCCT's
# sphere tessellation leaves pole-seam vertices unwelded — an export artifact,
# not a real defect. `get_manifold_stats` now asks OCCT directly
# (`BRepCheck_Analyzer` via CadQuery's `Shape.isValid()`), which correctly
# reports this solid as valid.
schema_version: "3.0"

metadata:
  name: T0 Sphere
  description: "Tier 0 primitive ladder: sphere volume/bbox against the closed-form 4/3*pi*r^3 formula"
  version: "1.0"

parameters:
  sph_r: 18

parts:
  ball:
    primitive: sphere
    parameters:
      radius: ${sph_r}

export:
  default_part: ball

expect:
  final: ball
  volume: 24429.02447431423
  bbox: [36, 36, 36]
  components: 1
  watertight: true
  tol: { volume: 0.01 }
