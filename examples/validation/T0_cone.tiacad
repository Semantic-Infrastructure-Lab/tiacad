# Tier 0 — Cone primitive, closed-form ground truth (apex cone, radius2=0).
# Volume = 1/3*pi*r1*h*(r1^2+r1*r2+r2^2) — NOT the pure 1/3*pi*r^2*h apex formula:
# cadquery_backend.py::create_cone builds a "true" cone as a frustum lofted to a
# radius2=0.001 top circle (CadQuery rejects a literal 0 loft radius), so the exact
# kernel volume includes that sliver. tol below absorbs kernel/mesh rounding only.
schema_version: "3.0"

metadata:
  name: T0 Cone
  description: "Tier 0 primitive ladder: cone volume/bbox against the closed-form 1/3*pi*r^2*h formula"
  version: "1.0"

parameters:
  cone_r: 20
  cone_h: 36

parts:
  spike:
    primitive: cone
    parameters:
      radius1: ${cone_r}
      radius2: 0
      height: ${cone_h}

export:
  default_part: spike

expect:
  final: spike
  volume: 15080.39875716698
  bbox: [40, 40, 36]
  watertight: true
  components: 1
  tol: { volume: 0.01 }
